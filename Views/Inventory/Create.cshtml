@model Product

@{
    ViewData["Title"] = "Agregar Producto";
}

<div class="container mt-4">
    <h1>➕ Agregar Producto</h1>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Cantidad</label>
                    <input asp-for="Stock" type="number" class="form-control" required min="0" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Precio</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required min="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">✅ Guardar</button>
                <a href="/Inventory" class="btn btn-secondary">⬅️ Cancelar</a>
            </form>
        </div>
    </div>
</div>